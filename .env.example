# Resend API key — get from https://resend.com/api-keys
RESEND_API_KEY=

# Where contact form submissions are delivered
CONTACT_TO_EMAIL=

# The "from" address shown on emails (must be a verified Resend domain)
CONTACT_FROM_EMAIL=

# Google Maps embed URL — paste the full src URL from the Maps embed dialog
# Leave empty to show the "Map coming soon" placeholder
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL=
