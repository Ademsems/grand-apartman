# Resend API key — get from https://resend.com/api-keys
RESEND_API_KEY=

# Where contact form submissions are delivered
CONTACT_TO_EMAIL=

# The "from" address shown on emails (must be a verified Resend domain/address)
CONTACT_FROM_EMAIL=

# Google Maps embed URL for the Location section.
# To get your own: open Google Maps → navigate to Podhajska → Share → Embed a map → copy the src URL.
# The value below is a working embed for Podhajska town centre (no API key required).
# Add this value to Vercel environment variables as NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL.
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL=https://maps.google.com/maps?q=Podhajska,+Slovakia&t=&z=15&ie=UTF8&iwloc=&output=embed
